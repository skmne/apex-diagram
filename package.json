{
  "name": "apex-diagram",
  "displayName": "apex-diagram",
  "description": "Apex diagram generates UML class diagram based on the apex code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-classes-bar",
          "title": "Apex Diagram",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apex-classes-view",
        "contents": "No apex classes found"
      }
    ],
    "views": {
      "apex-classes-bar": [
        {
          "id": "apex-classes-view",
          "name": "Apex Classes",
          "icon": "resources/logo.svg",
          "contextualTitle": "Apex Diagram"
        }
      ]
    },
    "commands": [
      {
        "command": "diagram-workspace.start",
        "title": "Open Apex Diagram workspace",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.openWorkspace",
        "title": "Show Diagram",
        "icon": "$(gather)"
      },
      {
        "command": "apex-classes-view.refreshEntry",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "apex-classes-view.addEntry",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "apex-classes-view.removeEntry",
        "title": "Delete",
        "icon": "$(remove)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apex-classes-view.refreshEntry",
          "when": "view == apex-classes-view",
          "group": "navigation"
        },
        {
          "command": "apex-classes-view.openWorkspace",
          "when": "view == apex-classes-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apex-classes-view.addEntry",
          "when": "view == apex-classes-view && viewItem == add_context",
          "group": "inline"
        },
        {
          "command": "apex-classes-view.removeEntry",
          "when": "view == apex-classes-view && viewItem == remove_context",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jsforce": "^1.11.3",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.78.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.39.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "jsforce": "^1.11.0"
  }
}

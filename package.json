{
  "name": "apex-diagram",
  "displayName": "apex-diagram",
  "description": "Apex diagram generates UML class diagram based on the apex code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-classes-bar",
          "title": "Apex Diagram",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apex-classes-view",
        "contents": "No apex classes found"
      }
    ],
    "views": {
      "apex-classes-bar": [
        {
          "id": "active-apex-classes-view",
          "name": "Active Apex Classes",
          "icon": "resources/logo.svg",
          "contextualTitle": "Apex Diagram",
          "visibility": "collapsed"
        },
        {
          "id": "apex-classes-view",
          "name": "Apex Classes",
          "icon": "resources/logo.svg",
          "contextualTitle": "Apex Diagram"
        }
      ]
    },
    "commands": [
      {
        "command": "diagram-workspace.start",
        "title": "Open Apex Diagram workspace",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.openWorkspace",
        "title": "Show Diagram",
        "icon": "$(gather)"
      },
      {
        "command": "apex-classes-view.refreshEntry",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "apex-classes-view.addEntry",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "active-apex-classes-view.removeEntry",
        "title": "Delete",
        "icon": "$(remove)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apex-classes-view.refreshEntry",
          "when": "view == apex-classes-view",
          "group": "navigation"
        },
        {
          "command": "apex-classes-view.openWorkspace",
          "when": "view == apex-classes-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apex-classes-view.addEntry",
          "when": "view == apex-classes-view && viewItem == add_context",
          "group": "inline"
        },
        {
          "command": "active-apex-classes-view.removeEntry",
          "when": "view == active-apex-classes-view && viewItem == remove_context",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:webview && tsc -p ./",
    "build:webview": "webpack --config webpack.webview.config.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "webpack --config webpack.webview.config.js --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src/",
    "test": "vscode-test",
    "test:unit": "tsc -p ./ && mocha --ui tdd out/test/suite/node.test.js out/test/suite/link.test.js out/test/suite/dependencyAnalaizer.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.19.11",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "mocha": "^10.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@alesik/uml-diagram": "^0.1.0",
    "jsforce": "^3.10.14"
  }
}

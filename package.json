{
  "name": "apex-diagram",
  "displayName": "Apex Diagram",
  "description": "Visualize Salesforce Apex class dependencies as an interactive UML-style diagram.",
  "version": "0.0.1",
  "publisher": "skmne94",
  "author": "Aliaksandr Lesik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skmne/apex-diagram.git"
  },
  "homepage": "https://github.com/skmne/apex-diagram#readme",
  "bugs": {
    "url": "https://github.com/skmne/apex-diagram/issues"
  },
  "keywords": [
    "apex",
    "salesforce",
    "uml",
    "diagram",
    "dependencies",
    "dependency-graph",
    "tooling-api",
    "sfdx",
    "visualization"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "preview": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-classes-bar",
          "title": "Apex Diagram",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apex-classes-view",
        "contents": "No Apex classes found."
      }
    ],
    "views": {
      "apex-classes-bar": [
        {
          "id": "diagram-items-view",
          "name": "Diagram Items",
          "contextualTitle": "Apex Diagram",
          "visibility": "collapsed"
        },
        {
          "id": "apex-classes-view",
          "name": "Apex Classes",
          "contextualTitle": "Apex Diagram"
        }
      ]
    },
    "commands": [
      {
        "command": "diagram-workspace.start",
        "title": "Open Apex Diagram Workspace",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.openWorkspace",
        "title": "Show Diagram",
        "icon": "$(gather)",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.refreshEntry",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.clearCache",
        "title": "Clear Cache",
        "icon": "$(database)",
        "category": "Apex Diagram"
      },
      {
        "command": "diagram-workspace.clear",
        "title": "Clear Diagram",
        "icon": "$(clear-all)",
        "category": "Apex Diagram"
      },
      {
        "command": "apex-classes-view.addEntry",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "apex-classes-view.addEntry.loading",
        "title": "Adding",
        "icon": "$(sync~spin)"
      },
      {
        "command": "diagram-items-view.removeEntry",
        "title": "Remove",
        "icon": "$(remove)"
      },
      {
        "command": "diagram-items-view.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apex-classes-view.refreshEntry",
          "when": "view == apex-classes-view",
          "group": "navigation"
        },
        {
          "command": "apex-classes-view.openWorkspace",
          "when": "view == diagram-items-view",
          "group": "navigation@2"
        },
        {
          "command": "apex-classes-view.clearCache",
          "when": "view == apex-classes-view",
          "group": "navigation"
        },
        {
          "command": "diagram-workspace.clear",
          "when": "view == diagram-items-view",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "apex-classes-view.addEntry",
          "when": "view == apex-classes-view && viewItem == add_context",
          "group": "inline"
        },
        {
          "command": "apex-classes-view.addEntry.loading",
          "when": "view == apex-classes-view && viewItem == loading_context",
          "group": "inline"
        },
        {
          "command": "diagram-items-view.removeEntry",
          "when": "view == diagram-items-view && viewItem == remove_context",
          "group": "inline@2"
        },
        {
          "command": "diagram-items-view.openFile",
          "when": "view == diagram-items-view && viewItem == remove_context",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:webview && tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "build:webview": "webpack --config webpack.webview.config.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "webpack --config webpack.webview.config.js --watch",
    "pretest": "npm run compile && npm run compile:test && npm run lint",
    "lint": "eslint src/",
    "test": "vscode-test",
    "test:unit": "npm run compile:test && mocha --ui tdd out-test/test/suite/apexClassKey.test.js out-test/test/suite/node.test.js out-test/test/suite/link.test.js out-test/test/suite/diagramState.test.js out-test/test/suite/dependencyAnalyzer.test.js out-test/test/suite/SymbolTableCache.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.19.11",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "mocha": "^10.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@alesik/uml-diagram": "^0.2.2",
    "jsforce": "^3.10.14"
  }
}
